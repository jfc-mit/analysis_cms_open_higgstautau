\@writefile{lot}{\contentsline {table}{\numberline {24}{\ignorespaces Signal injection test results for the NN score approach. All injected values are recovered with pulls \textless {} 0.01, confirming unbiased signal extraction.\relax }}{44}{table.caption.81}\protected@file@percent }
\newlabel{tbl:injection-nn}{{24}{44}{Signal injection test results for the NN score approach. All injected values are recovered with pulls \textless {} 0.01, confirming unbiased signal extraction.\relax }{table.caption.81}{}}
\@writefile{lot}{\contentsline {table}{\numberline {25}{\ignorespaces Signal injection test results for the visible mass approach.\relax }}{44}{table.caption.82}\protected@file@percent }
\newlabel{tbl:injection-mvis}{{25}{44}{Signal injection test results for the visible mass approach.\relax }{table.caption.82}{}}
\@writefile{lot}{\contentsline {table}{\numberline {26}{\ignorespaces Signal injection test results for the collinear mass approach.\relax }}{44}{table.caption.83}\protected@file@percent }
\newlabel{tbl:injection-mcol}{{26}{44}{Signal injection test results for the collinear mass approach.\relax }{table.caption.83}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {41}{\ignorespaces Signal injection linearity test for all three fitting approaches. The recovered signal strength \(\hat {\mitmu }\) (y-axis) is plotted against the injected value \(\mitmu _\mathrm {inject}\) (x-axis). All points lie on the diagonal (\(\hat {\mitmu } = \mitmu _\mathrm {inject}\)), confirming unbiased recovery across the full range of tested signal strengths. The error bars show the fit uncertainty \(\mitsigma (\mitmu )\) at each injection point.\relax }}{45}{figure.caption.84}\protected@file@percent }
\newlabel{fig:signal-injection}{{41}{45}{Signal injection linearity test for all three fitting approaches. The recovered signal strength \(\hat {\mu }\) (y-axis) is plotted against the injected value \(\mu _\mathrm {inject}\) (x-axis). All points lie on the diagonal (\(\hat {\mu } = \mu _\mathrm {inject}\)), confirming unbiased recovery across the full range of tested signal strengths. The error bars show the fit uncertainty \(\sigma (\mu )\) at each injection point.\relax }{figure.caption.84}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {10.2}Nuisance parameter pulls}{45}{subsection.10.2}\protected@file@percent }
\newlabel{sec:val-pulls}{{10.2}{45}{Nuisance parameter pulls}{subsection.10.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {42}{\ignorespaces Nuisance parameter best-fit values and post-fit uncertainties for the NN score Asimov fit. The black points show the best-fit values (all zero on Asimov data) with error bars indicating the post-fit uncertainties. The green (yellow) bands show the 1\(\mitsigma \) (2\(\mitsigma \)) prior constraint regions. Several parameters, particularly the shape systematics (TES, MES, MET, JES), have post-fit uncertainties significantly smaller than the prior, indicating that the template shapes in the fit provide constraining information.\relax }}{46}{figure.caption.85}\protected@file@percent }
\newlabel{fig:np-pulls}{{42}{46}{Nuisance parameter best-fit values and post-fit uncertainties for the NN score Asimov fit. The black points show the best-fit values (all zero on Asimov data) with error bars indicating the post-fit uncertainties. The green (yellow) bands show the 1\(\sigma \) (2\(\sigma \)) prior constraint regions. Several parameters, particularly the shape systematics (TES, MES, MET, JES), have post-fit uncertainties significantly smaller than the prior, indicating that the template shapes in the fit provide constraining information.\relax }{figure.caption.85}{}}
