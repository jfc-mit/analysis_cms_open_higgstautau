\@writefile{toc}{\contentsline {subsection}{\numberline {9.1}Pre-fit templates}{39}{subsection.9.1}\protected@file@percent }
\newlabel{sec:prefit-templates}{{9.1}{39}{Pre-fit templates}{subsection.9.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {34}{\ignorespaces Pre-fit visible mass template in the Baseline category. The stacked backgrounds (\(Z\to \mittau \mittau \), \(Z\to \ell \ell \), \(t\bar {t}\), W+jets, QCD) are shown with the ggH and VBF signal contributions scaled by 10 for visibility. Asimov data points (generated as the sum of all backgrounds plus SM signal) overlay the total prediction. The \(Z\to \mittau \mittau \) background dominates with a peak near 60-80 GeV, while the Higgs signal contributes a broad excess in the 100-150 GeV region.\relax }}{40}{figure.caption.73}\protected@file@percent }
\newlabel{fig:template-mvis-baseline}{{34}{40}{Pre-fit visible mass template in the Baseline category. The stacked backgrounds (\(Z\to \tau \tau \), \(Z\to \ell \ell \), \(t\bar {t}\), W+jets, QCD) are shown with the ggH and VBF signal contributions scaled by 10 for visibility. Asimov data points (generated as the sum of all backgrounds plus SM signal) overlay the total prediction. The \(Z\to \tau \tau \) background dominates with a peak near 60-80 GeV, while the Higgs signal contributes a broad excess in the 100-150 GeV region.\relax }{figure.caption.73}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {35}{\ignorespaces Pre-fit visible mass template in the VBF category. The lower statistics compared to Baseline are evident, with \(t\bar {t}\) and W+jets becoming significant backgrounds alongside \(Z\to \mittau \mittau \). The VBF signal (blue, scaled x10) is comparable in magnitude to the ggH contamination (red, scaled x10) in this category.\relax }}{40}{figure.caption.74}\protected@file@percent }
\newlabel{fig:template-mvis-vbf}{{35}{40}{Pre-fit visible mass template in the VBF category. The lower statistics compared to Baseline are evident, with \(t\bar {t}\) and W+jets becoming significant backgrounds alongside \(Z\to \tau \tau \). The VBF signal (blue, scaled x10) is comparable in magnitude to the ggH contamination (red, scaled x10) in this category.\relax }{figure.caption.74}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {36}{\ignorespaces Pre-fit NN discriminant score template in the Baseline category. The backgrounds peak at low NN scores while the signal peaks at high scores, demonstrating the discriminating power of the NN classifier. The clear separation between signal and background in this observable is the primary driver of the improved sensitivity of the NN approach.\relax }}{41}{figure.caption.75}\protected@file@percent }
\newlabel{fig:template-nn-baseline}{{36}{41}{Pre-fit NN discriminant score template in the Baseline category. The backgrounds peak at low NN scores while the signal peaks at high scores, demonstrating the discriminating power of the NN classifier. The clear separation between signal and background in this observable is the primary driver of the improved sensitivity of the NN approach.\relax }{figure.caption.75}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {37}{\ignorespaces Pre-fit NN discriminant score template in the VBF category. The signal-background separation pattern is similar to Baseline, with reduced statistics. The NN exploits the VBF-specific kinematic features (forward jets, large dijet mass) to further enhance the signal discrimination in this category.\relax }}{41}{figure.caption.76}\protected@file@percent }
\newlabel{fig:template-nn-vbf}{{37}{41}{Pre-fit NN discriminant score template in the VBF category. The signal-background separation pattern is similar to Baseline, with reduced statistics. The NN exploits the VBF-specific kinematic features (forward jets, large dijet mass) to further enhance the signal discrimination in this category.\relax }{figure.caption.76}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {38}{\ignorespaces Pre-fit collinear mass template in the Baseline category. The broader distribution compared to the visible mass reflects the inclusion of events with unphysical collinear solutions that fall back to the visible mass. For events with physical solutions, the collinear mass provides improved mass resolution, producing a sharper \(Z\) peak and better Higgs signal separation.\relax }}{42}{figure.caption.77}\protected@file@percent }
\newlabel{fig:template-mcol-baseline}{{38}{42}{Pre-fit collinear mass template in the Baseline category. The broader distribution compared to the visible mass reflects the inclusion of events with unphysical collinear solutions that fall back to the visible mass. For events with physical solutions, the collinear mass provides improved mass resolution, producing a sharper \(Z\) peak and better Higgs signal separation.\relax }{figure.caption.77}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {39}{\ignorespaces Pre-fit collinear mass template in the VBF category. The reduced statistics and higher unphysical solution fractions for background processes result in a broader distribution compared to the Baseline category.\relax }}{42}{figure.caption.78}\protected@file@percent }
\newlabel{fig:template-mcol-vbf}{{39}{42}{Pre-fit collinear mass template in the VBF category. The reduced statistics and higher unphysical solution fractions for background processes result in a broader distribution compared to the Baseline category.\relax }{figure.caption.78}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {9.2}Asimov fit results}{42}{subsection.9.2}\protected@file@percent }
\newlabel{sec:asimov-results}{{9.2}{42}{Asimov fit results}{subsection.9.2}{}}
\citation{ref-CMS:2014nkk}
\@writefile{lot}{\contentsline {table}{\numberline {23}{\ignorespaces Expected (Asimov) fit results for all three fitting approaches. The fitted signal strength \(\hat {\mitmu }\) is unity by construction on Asimov data. The NN score approach provides the best expected precision with \(\mitsigma (\mitmu ) = 1.15\).\relax }}{43}{table.caption.79}\protected@file@percent }
\newlabel{tbl:asimov-results}{{23}{43}{Expected (Asimov) fit results for all three fitting approaches. The fitted signal strength \(\hat {\mu }\) is unity by construction on Asimov data. The NN score approach provides the best expected precision with \(\sigma (\mu ) = 1.15\).\relax }{table.caption.79}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {9.3}CLs limit scan}{43}{subsection.9.3}\protected@file@percent }
\newlabel{sec:cls-results}{{9.3}{43}{CLs limit scan}{subsection.9.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {40}{\ignorespaces CL\(_\mathrm {s}\) values as a function of the signal strength \(\mitmu \) for all three fitting approaches. The horizontal dashed line indicates CL\(_\mathrm {s} = 0.05\) (95\% CL). The intersection with each curve gives the expected 95\% CL upper limit: 2.36 for NN score, 6.20 for visible mass, and 7.81 for collinear mass. The NN score approach provides the tightest expected limit, consistent with its superior discriminating power.\relax }}{43}{figure.caption.80}\protected@file@percent }
\newlabel{fig:cls-scan}{{40}{43}{CL\(_\mathrm {s}\) values as a function of the signal strength \(\mu \) for all three fitting approaches. The horizontal dashed line indicates CL\(_\mathrm {s} = 0.05\) (95\% CL). The intersection with each curve gives the expected 95\% CL upper limit: 2.36 for NN score, 6.20 for visible mass, and 7.81 for collinear mass. The NN score approach provides the tightest expected limit, consistent with its superior discriminating power.\relax }{figure.caption.80}{}}
