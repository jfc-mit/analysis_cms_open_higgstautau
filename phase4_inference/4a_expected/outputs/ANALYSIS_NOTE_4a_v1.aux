\newlabel{tbl:syst-summary}{{22}{38}{Summary of all systematic uncertainties, ordered by impact on the signal strength \(\mu \). The ``Type'' column indicates whether the systematic affects the template normalization (Norm) or shape (Shape). The impact values are for the NN score approach on Asimov data.\relax }{table.22}{}}
\@writefile{toc}{\contentsline {section}{\numberline {9}Expected Results}{39}{section.9}\protected@file@percent }
