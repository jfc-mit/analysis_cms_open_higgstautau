\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces Comparison of tau isolation working points. The \(\mitchi ^2\)/ndf is computed in the \(Z\) peak region (60-120 GeV visible mass).\relax }}{7}{table.caption.14}\protected@file@percent }
\newlabel{tbl:tauid-wp}{{5}{7}{Comparison of tau isolation working points. The \(\chi ^2\)/ndf is computed in the \(Z\) peak region (60-120 GeV visible mass).\relax }{table.caption.14}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Visible mass distribution with the VLoose tau isolation working point. The data points show the observed collision data, and the stacked histogram shows the MC prediction for Z+jets (DY), \(t\bar {t}\), and W+jets backgrounds. The excess of data over MC in the Z peak region (\(\mitchi ^2\)/ndf = 4.08) indicates poor modeling at this working point, motivating the choice of a tighter isolation requirement.\relax }}{8}{figure.caption.15}\protected@file@percent }
\newlabel{fig:tauid-vloose}{{1}{8}{Visible mass distribution with the VLoose tau isolation working point. The data points show the observed collision data, and the stacked histogram shows the MC prediction for Z+jets (DY), \(t\bar {t}\), and W+jets backgrounds. The excess of data over MC in the Z peak region (\(\chi ^2\)/ndf = 4.08) indicates poor modeling at this working point, motivating the choice of a tighter isolation requirement.\relax }{figure.caption.15}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Visible mass distribution with the Loose tau isolation working point. The data/MC agreement is substantially improved relative to VLoose (\(\mitchi ^2\)/ndf = 2.96 in the Z peak region), while retaining 20\% more signal yield than the Medium working point. The residual data excess is attributed to the missing QCD multijet contribution.\relax }}{8}{figure.caption.16}\protected@file@percent }
\newlabel{fig:tauid-loose}{{2}{8}{Visible mass distribution with the Loose tau isolation working point. The data/MC agreement is substantially improved relative to VLoose (\(\chi ^2\)/ndf = 2.96 in the Z peak region), while retaining 20\% more signal yield than the Medium working point. The residual data excess is attributed to the missing QCD multijet contribution.\relax }{figure.caption.16}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Visible mass distribution with the Medium tau isolation working point. The \(\mitchi ^2\)/ndf of 2.95 is comparable to the Loose working point, but the signal yield is reduced by 20\%. The slightly lower Data/MC ratio (1.06 vs 1.12) suggests that the QCD multijet contamination is smaller at tighter isolation, as expected.\relax }}{9}{figure.caption.17}\protected@file@percent }
\newlabel{fig:tauid-medium}{{3}{9}{Visible mass distribution with the Medium tau isolation working point. The \(\chi ^2\)/ndf of 2.95 is comparable to the Loose working point, but the signal yield is reduced by 20\%. The slightly lower Data/MC ratio (1.06 vs 1.12) suggests that the QCD multijet contamination is smaller at tighter isolation, as expected.\relax }{figure.caption.17}{}}
