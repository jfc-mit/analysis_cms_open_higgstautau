\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Monte Carlo simulation samples. The cross-section for signal samples is \(\mitsigma _\mathrm {prod} \times \mathrm {BR}(H\to \mittau \mittau )\) using YR4 values (\citeproc {ref-LHCHiggsCrossSectionWorkingGroup:2016ypw}{{Florian et al.} 2017}). The \(t\bar {t}\) cross-section is calculated at NNLO+NNLL (\citeproc {ref-Czakon:2011xx}{Czakon and Mitov 2014}). W+jets cross-sections are LO MadGraph values. The per-event weight is \(\mitsigma \times L_\mathrm {int} / N_\mathrm {gen}\) with \(L_\mathrm {int} = 11{,}467\) pb\(^{-1}\).\relax }}{5}{table.caption.5}\protected@file@percent }
\newlabel{tbl:mc-samples}{{2}{5}{Monte Carlo simulation samples. The cross-section for signal samples is \(\sigma _\mathrm {prod} \times \mathrm {BR}(H\to \tau \tau )\) using YR4 values (\citeproc {ref-LHCHiggsCrossSectionWorkingGroup:2016ypw}{{Florian et al.} 2017}). The \(t\bar {t}\) cross-section is calculated at NNLO+NNLL (\citeproc {ref-Czakon:2011xx}{Czakon and Mitov 2014}). W+jets cross-sections are LO MadGraph values. The per-event weight is \(\sigma \times L_\mathrm {int} / N_\mathrm {gen}\) with \(L_\mathrm {int} = 11{,}467\) pb\(^{-1}\).\relax }{table.caption.5}{}}
