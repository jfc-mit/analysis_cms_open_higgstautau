\newlabel{fig:nn-roc}{{8}{17}{ROC curves for the NN classifier on the training, validation, and test datasets. The three curves are consistent, confirming no overtraining. The test AUC of 0.825 demonstrates significant discriminating power between signal and background.\relax }{figure.caption.37}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {5.2.5}NN input variable quality gate}{17}{subsubsection.5.2.5}\protected@file@percent }
\newlabel{nn-input-variable-quality-gate}{{5.2.5}{17}{NN input variable quality gate}{subsubsection.5.2.5}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {5.2.6}NN score distributions}{17}{subsubsection.5.2.6}\protected@file@percent }
\newlabel{nn-score-distributions}{{5.2.6}{17}{NN score distributions}{subsubsection.5.2.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Overtraining check for the NN classifier. The NN score distributions are shown for signal (red) and background (blue), overlaying the training set (filled histogram) and test set (points with error bars). The good agreement between training and test distributions in both classes confirms the absence of overtraining, consistent with the KS test results in Table\nobreakspace  {}\ref  {tbl:nn-overtraining}.\relax }}{18}{figure.caption.38}\protected@file@percent }
\newlabel{fig:nn-overtraining}{{9}{18}{Overtraining check for the NN classifier. The NN score distributions are shown for signal (red) and background (blue), overlaying the training set (filled histogram) and test set (points with error bars). The good agreement between training and test distributions in both classes confirms the absence of overtraining, consistent with the KS test results in Table~\ref {tbl:nn-overtraining}.\relax }{figure.caption.38}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces NN input feature importance estimated from the first-layer weight magnitudes. The visible mass (\(m_\mathrm {vis}\)) is the most important feature, followed by \(\mitDelta R(\mitmu , \mittau _\mathrm {h})\) and \(E_\mathrm {T}^\mathrm {miss}\). The importance ranking generally follows the individual ROC AUC values in Table\nobreakspace  {}\ref  {tbl:nn-features}, with the exception of \(\mitDelta R\) which has elevated importance due to its correlation with other kinematic variables.\relax }}{18}{figure.caption.39}\protected@file@percent }
\newlabel{fig:nn-importance}{{10}{18}{NN input feature importance estimated from the first-layer weight magnitudes. The visible mass (\(m_\mathrm {vis}\)) is the most important feature, followed by \(\Delta R(\mu , \tau _\mathrm {h})\) and \(E_\mathrm {T}^\mathrm {miss}\). The importance ranking generally follows the individual ROC AUC values in Table~\ref {tbl:nn-features}, with the exception of \(\Delta R\) which has elevated importance due to its correlation with other kinematic variables.\relax }{figure.caption.39}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces NN discriminant score distribution in the Baseline category. Background events peak at low NN scores (near 0) while signal events (shown scaled by x10) peak at high scores (near 1), demonstrating the discriminating power of the NN classifier. The QCD template is constructed by evaluating the trained NN on same-sign data events, ensuring consistent treatment of the data-driven QCD background in the fitting observable.\relax }}{19}{figure.caption.40}\protected@file@percent }
\newlabel{fig:nn-score-baseline}{{11}{19}{NN discriminant score distribution in the Baseline category. Background events peak at low NN scores (near 0) while signal events (shown scaled by x10) peak at high scores (near 1), demonstrating the discriminating power of the NN classifier. The QCD template is constructed by evaluating the trained NN on same-sign data events, ensuring consistent treatment of the data-driven QCD background in the fitting observable.\relax }{figure.caption.40}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {12}{\ignorespaces NN discriminant score distribution in the VBF category. The separation between signal and background is similar to the Baseline category, but with reduced statistics. The ratio panel shows larger fluctuations due to the limited event count in the VBF category.\relax }}{19}{figure.caption.41}\protected@file@percent }
\newlabel{fig:nn-score-vbf}{{12}{19}{NN discriminant score distribution in the VBF category. The separation between signal and background is similar to the Baseline category, but with reduced statistics. The ratio panel shows larger fluctuations due to the limited event count in the VBF category.\relax }{figure.caption.41}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {5.2.7}Alternative classifier: BDT comparison}{19}{subsubsection.5.2.7}\protected@file@percent }
\newlabel{alternative-classifier-bdt-comparison}{{5.2.7}{19}{Alternative classifier: BDT comparison}{subsubsection.5.2.7}{}}
\@writefile{lot}{\contentsline {table}{\numberline {17}{\ignorespaces Performance comparison between the primary NN and alternative BDT classifiers. The NN outperforms the BDT by 0.005 AUC on the test set, with less overtraining.\relax }}{20}{table.caption.42}\protected@file@percent }
\newlabel{tbl:bdt-comparison}{{17}{20}{Performance comparison between the primary NN and alternative BDT classifiers. The NN outperforms the BDT by 0.005 AUC on the test set, with less overtraining.\relax }{table.caption.42}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {13}{\ignorespaces ROC curve comparison between the primary NN classifier and the alternative BDT. The NN achieves AUC = 0.825 vs BDT AUC = 0.820 on the test set. The small difference confirms the NN as the preferred classifier, with the BDT result serving as a cross-check of the MVA approach.\relax }}{20}{figure.caption.43}\protected@file@percent }
\newlabel{fig:bdt-roc}{{13}{20}{ROC curve comparison between the primary NN classifier and the alternative BDT. The NN achieves AUC = 0.825 vs BDT AUC = 0.820 on the test set. The small difference confirms the NN as the preferred classifier, with the BDT result serving as a cross-check of the MVA approach.\relax }{figure.caption.43}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {14}{\ignorespaces BDT overtraining check. The BDT score distributions overlay training (filled) and test (points) samples for signal and background. The signal class shows marginal overtraining (KS \(p\)-value = 0.0007), with the training distribution shifted slightly toward higher scores compared to the test distribution. This is consistent with the larger train-test AUC gap observed for the BDT.\relax }}{21}{figure.caption.44}\protected@file@percent }
\newlabel{fig:bdt-overtraining}{{14}{21}{BDT overtraining check. The BDT score distributions overlay training (filled) and test (points) samples for signal and background. The signal class shows marginal overtraining (KS \(p\)-value = 0.0007), with the training distribution shifted slightly toward higher scores compared to the test distribution. This is consistent with the larger train-test AUC gap observed for the BDT.\relax }{figure.caption.44}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.3}Collinear approximation mass}{21}{subsection.5.3}\protected@file@percent }
\newlabel{sec:disc-mcol}{{5.3}{21}{Collinear approximation mass}{subsection.5.3}{}}
\newlabel{eq:mcol}{{12}{21}{Collinear approximation mass}{section*.45}{}}
\newlabel{eq:mcol-fractions}{{13}{21}{Collinear approximation mass}{section*.46}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {5.3.1}Physical solution fractions}{21}{subsubsection.5.3.1}\protected@file@percent }
\newlabel{physical-solution-fractions}{{5.3.1}{21}{Physical solution fractions}{subsubsection.5.3.1}{}}
\@writefile{lot}{\contentsline {table}{\numberline {18}{\ignorespaces Physical solution fractions for the collinear approximation. The ggH signal unphysical fraction of 45.7\% is below the 50\% go/no-go threshold. Background processes show higher unphysical fractions, consistent with the collinear assumption being less appropriate for fake taus and complex final states.\relax }}{22}{table.caption.47}\protected@file@percent }
\newlabel{tbl:mcol-physical}{{18}{22}{Physical solution fractions for the collinear approximation. The ggH signal unphysical fraction of 45.7\% is below the 50\% go/no-go threshold. Background processes show higher unphysical fractions, consistent with the collinear assumption being less appropriate for fake taus and complex final states.\relax }{table.caption.47}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {15}{\ignorespaces Collinear mass distribution in the Baseline category. The QCD template is computed from the collinear mass values of same-sign events, ensuring consistency with the fitting observable. The broader distribution compared to the visible mass reflects the inclusion of unphysical collinear solutions that fall back to the visible mass. Events with physical solutions produce the characteristic peaks at the Z and Higgs masses.\relax }}{22}{figure.caption.48}\protected@file@percent }
\newlabel{fig:mcol-baseline}{{15}{22}{Collinear mass distribution in the Baseline category. The QCD template is computed from the collinear mass values of same-sign events, ensuring consistency with the fitting observable. The broader distribution compared to the visible mass reflects the inclusion of unphysical collinear solutions that fall back to the visible mass. Events with physical solutions produce the characteristic peaks at the Z and Higgs masses.\relax }{figure.caption.48}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {16}{\ignorespaces Collinear mass distribution in the VBF category. The reduced statistics and higher unphysical fractions for background processes make this observable less powerful in the VBF category. Nevertheless, the collinear mass provides complementary information to the visible mass through the improved mass resolution for events with physical solutions.\relax }}{23}{figure.caption.49}\protected@file@percent }
\newlabel{fig:mcol-vbf}{{16}{23}{Collinear mass distribution in the VBF category. The reduced statistics and higher unphysical fractions for background processes make this observable less powerful in the VBF category. Nevertheless, the collinear mass provides complementary information to the visible mass through the improved mass resolution for events with physical solutions.\relax }{figure.caption.49}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.4}Approach comparison}{23}{subsection.5.4}\protected@file@percent }
\newlabel{sec:disc-comparison}{{5.4}{23}{Approach comparison}{subsection.5.4}{}}
\@writefile{lot}{\contentsline {table}{\numberline {19}{\ignorespaces Comparison of the three fitting approaches. The NN discriminant provides the best expected significance, improving over the visible mass baseline by 89\% and over the collinear mass by a factor of 2.2. These pre-fit estimates use a simple \(S/\sqrt  {B}\) counting metric; the profile likelihood fit results are presented in Section\nobreakspace  {}\ref  {sec:expected-results}.\relax }}{23}{table.caption.50}\protected@file@percent }
\newlabel{tbl:approach-comparison}{{19}{23}{Comparison of the three fitting approaches. The NN discriminant provides the best expected significance, improving over the visible mass baseline by 89\% and over the collinear mass by a factor of 2.2. These pre-fit estimates use a simple \(S/\sqrt {B}\) counting metric; the profile likelihood fit results are presented in Section~\ref {sec:expected-results}.\relax }{table.caption.50}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {17}{\ignorespaces Comparison of expected significance across the three fitting approaches: visible mass template (\(m_\mathrm {vis}\)), neural network discriminant (NN score), and collinear approximation mass (\(m_\mathrm {col}\)). All approaches include consistent treatment of the data-driven QCD background. The NN discriminant provides the best expected significance at 1.52\(\mitsigma \), representing an 89\% improvement over the cut-based visible mass approach.\relax }}{24}{figure.caption.51}\protected@file@percent }
\newlabel{fig:approach-comparison}{{17}{24}{Comparison of expected significance across the three fitting approaches: visible mass template (\(m_\mathrm {vis}\)), neural network discriminant (NN score), and collinear approximation mass (\(m_\mathrm {col}\)). All approaches include consistent treatment of the data-driven QCD background. The NN discriminant provides the best expected significance at 1.52\(\sigma \), representing an 89\% improvement over the cut-based visible mass approach.\relax }{figure.caption.51}{}}
\@writefile{toc}{\contentsline {section}{\numberline {6}Kinematic Distributions}{24}{section.6}\protected@file@percent }
\newlabel{sec:kinematics}{{6}{24}{Kinematic Distributions}{section.6}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {6.1}Baseline category distributions}{24}{subsection.6.1}\protected@file@percent }
\newlabel{sec:kin-baseline}{{6.1}{24}{Baseline category distributions}{subsection.6.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {18}{\ignorespaces Hadronic tau \(p_\mathrm {T}\) distribution in the Baseline category. The steeply falling spectrum is well modeled by the MC simulation. The tau \(p_\mathrm {T}\) is the most discriminating individual variable (ROC AUC = 0.695), as signal taus from Higgs decay tend to have harder \(p_\mathrm {T}\) spectra than those from \(Z\) decay due to the higher parent mass.\relax }}{25}{figure.caption.52}\protected@file@percent }
\newlabel{fig:tau-pt-baseline}{{18}{25}{Hadronic tau \(p_\mathrm {T}\) distribution in the Baseline category. The steeply falling spectrum is well modeled by the MC simulation. The tau \(p_\mathrm {T}\) is the most discriminating individual variable (ROC AUC = 0.695), as signal taus from Higgs decay tend to have harder \(p_\mathrm {T}\) spectra than those from \(Z\) decay due to the higher parent mass.\relax }{figure.caption.52}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {19}{\ignorespaces Muon \(p_\mathrm {T}\) distribution in the Baseline category. The distribution peaks near the 20 GeV selection threshold, with the MC prediction showing reasonable agreement with data. The slight excess in data at high \(p_\mathrm {T}\) is consistent with the QCD multijet contribution, which tends to produce higher-\(p_\mathrm {T}\) muons than the \(Z\to \mittau \mittau \) background.\relax }}{25}{figure.caption.53}\protected@file@percent }
\newlabel{fig:mu-pt-baseline}{{19}{25}{Muon \(p_\mathrm {T}\) distribution in the Baseline category. The distribution peaks near the 20 GeV selection threshold, with the MC prediction showing reasonable agreement with data. The slight excess in data at high \(p_\mathrm {T}\) is consistent with the QCD multijet contribution, which tends to produce higher-\(p_\mathrm {T}\) muons than the \(Z\to \tau \tau \) background.\relax }{figure.caption.53}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {20}{\ignorespaces Missing transverse energy (\(E_\mathrm {T}^\mathrm {miss}\)) distribution in the Baseline category. The data shows slightly higher MET than the MC prediction, consistent with the QCD multijet contribution. The MET is the fourth most discriminating variable (ROC AUC = 0.639), as the additional neutrinos from the Higgs decay produce more MET than the \(Z\to \mittau \mittau \) background.\relax }}{26}{figure.caption.54}\protected@file@percent }
\newlabel{fig:met-baseline}{{20}{26}{Missing transverse energy (\(E_\mathrm {T}^\mathrm {miss}\)) distribution in the Baseline category. The data shows slightly higher MET than the MC prediction, consistent with the QCD multijet contribution. The MET is the fourth most discriminating variable (ROC AUC = 0.639), as the additional neutrinos from the Higgs decay produce more MET than the \(Z\to \tau \tau \) background.\relax }{figure.caption.54}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {21}{\ignorespaces Jet multiplicity distribution in the Baseline category. The LO MadGraph MC shows known mismodeling at high jet multiplicities (\(N_\mathrm {jets} \geq 2\)), where the data exceeds the prediction. This is a well-documented feature of LO generators and is addressed in the statistical model through per-category normalization nuisance parameters.\relax }}{26}{figure.caption.55}\protected@file@percent }
\newlabel{fig:njets-baseline}{{21}{26}{Jet multiplicity distribution in the Baseline category. The LO MadGraph MC shows known mismodeling at high jet multiplicities (\(N_\mathrm {jets} \geq 2\)), where the data exceeds the prediction. This is a well-documented feature of LO generators and is addressed in the statistical model through per-category normalization nuisance parameters.\relax }{figure.caption.55}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {22}{\ignorespaces Angular separation \(\mitDelta R(\mitmu , \mittau _\mathrm {h})\) in the Baseline category. The distribution peaks near \(\mitpi \), consistent with the back-to-back topology expected from \(Z/H \to \mittau \mittau \) decays where the two tau leptons are produced approximately opposite in azimuth. The data/MC agreement is generally good, with a slight excess at large separations (\(\mitDelta R > 3.5\)) attributed to QCD multijet events.\relax }}{27}{figure.caption.56}\protected@file@percent }
\newlabel{fig:delta-r-baseline}{{22}{27}{Angular separation \(\Delta R(\mu , \tau _\mathrm {h})\) in the Baseline category. The distribution peaks near \(\pi \), consistent with the back-to-back topology expected from \(Z/H \to \tau \tau \) decays where the two tau leptons are produced approximately opposite in azimuth. The data/MC agreement is generally good, with a slight excess at large separations (\(\Delta R > 3.5\)) attributed to QCD multijet events.\relax }{figure.caption.56}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {6.2}VBF category distributions}{27}{subsection.6.2}\protected@file@percent }
\newlabel{sec:kin-vbf}{{6.2}{27}{VBF category distributions}{subsection.6.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {23}{\ignorespaces Hadronic tau \(p_\mathrm {T}\) distribution in the VBF category. The spectrum is harder than in the Baseline category due to the VBF event topology, where the Higgs boson recoils against the forward jet system. The reduced statistics lead to larger data/MC fluctuations in the ratio panel.\relax }}{27}{figure.caption.57}\protected@file@percent }
\newlabel{fig:tau-pt-vbf}{{23}{27}{Hadronic tau \(p_\mathrm {T}\) distribution in the VBF category. The spectrum is harder than in the Baseline category due to the VBF event topology, where the Higgs boson recoils against the forward jet system. The reduced statistics lead to larger data/MC fluctuations in the ratio panel.\relax }{figure.caption.57}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {24}{\ignorespaces Muon \(p_\mathrm {T}\) distribution in the VBF category. The VBF signal events (visible at the x10 scale) tend to have slightly harder muon \(p_\mathrm {T}\) compared to the Baseline category, reflecting the boost from the VBF production mechanism.\relax }}{28}{figure.caption.58}\protected@file@percent }
\newlabel{fig:mu-pt-vbf}{{24}{28}{Muon \(p_\mathrm {T}\) distribution in the VBF category. The VBF signal events (visible at the x10 scale) tend to have slightly harder muon \(p_\mathrm {T}\) compared to the Baseline category, reflecting the boost from the VBF production mechanism.\relax }{figure.caption.58}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {25}{\ignorespaces Missing transverse energy distribution in the VBF category. The \(t\bar {t}\) background contributes a larger fraction in this category compared to Baseline, due to the two-jet requirement that naturally selects \(t\bar {t}\) events. The MET distribution is broader than in Baseline, consistent with the more complex event topology.\relax }}{28}{figure.caption.59}\protected@file@percent }
\newlabel{fig:met-vbf}{{25}{28}{Missing transverse energy distribution in the VBF category. The \(t\bar {t}\) background contributes a larger fraction in this category compared to Baseline, due to the two-jet requirement that naturally selects \(t\bar {t}\) events. The MET distribution is broader than in Baseline, consistent with the more complex event topology.\relax }{figure.caption.59}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {26}{\ignorespaces Jet multiplicity distribution in the VBF category. By construction, all events have at least two jets. The distribution shows moderate agreement between data and MC, with the characteristic LO generator jet multiplicity mismodeling less pronounced since the VBF selection already requires two jets.\relax }}{29}{figure.caption.60}\protected@file@percent }
\newlabel{fig:njets-vbf}{{26}{29}{Jet multiplicity distribution in the VBF category. By construction, all events have at least two jets. The distribution shows moderate agreement between data and MC, with the characteristic LO generator jet multiplicity mismodeling less pronounced since the VBF selection already requires two jets.\relax }{figure.caption.60}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {27}{\ignorespaces Angular separation \(\mitDelta R(\mitmu , \mittau _\mathrm {h})\) in the VBF category. The distribution is slightly more forward-peaked than in the Baseline category, consistent with the more boosted kinematics of VBF events where the Higgs boson recoils against the dijet system.\relax }}{29}{figure.caption.61}\protected@file@percent }
\newlabel{fig:delta-r-vbf}{{27}{29}{Angular separation \(\Delta R(\mu , \tau _\mathrm {h})\) in the VBF category. The distribution is slightly more forward-peaked than in the Baseline category, consistent with the more boosted kinematics of VBF events where the Higgs boson recoils against the dijet system.\relax }{figure.caption.61}{}}
